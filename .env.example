# 启动时会先加载项目根目录 .env，再加载 .env.prod（后者覆盖前者）。线上可只用 .env.prod。
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_API_KEY=

# 私聊 AI 报错时是否在 QQ 里附带异常类型与简要信息（线上排查用，完成后改回 false）
MYBOT_AI_EXPOSE_ERROR_DETAIL=false

# ActivityWatch 上下文采集
ACTIVITY_CONTEXT_AW_BASE_URL=http://127.0.0.1:5600
ACTIVITY_CONTEXT_AW_BUCKET_PREFIXES=aw-watcher-window,aw-watcher-afk
ACTIVITY_CONTEXT_SUMMARY_MINUTES=15
ACTIVITY_CONTEXT_STALE_AFTER_MINUTES=20

# 云端只同步脱敏后的摘要；不需要时可留空
# 指向云端服务的接收地址，例如 https://你的域名/api/v1/summaries
ACTIVITY_CONTEXT_CLOUD_SYNC_URL=https://49.233.195.96/api/v1/summaries
# 与云端 ACTIVITY_CONTEXT_SERVER_TOKEN 一致
ACTIVITY_CONTEXT_CLOUD_SYNC_TOKEN=KeiBot

# 云端服务（tools/activity_context/cloud_server）部署时用
# ACTIVITY_CONTEXT_SERVER_TOKEN=与上面 CLOUD_SYNC_TOKEN 相同即可
# ACTIVITY_CONTEXT_SERVER_HOST=0.0.0.0
# ACTIVITY_CONTEXT_SERVER_PORT=8780
# ACTIVITY_CONTEXT_SERVER_DB_PATH=
